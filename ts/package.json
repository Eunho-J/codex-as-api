{
  "name": "codex-as-api",
  "version": "0.1.0",
  "description": "Local OpenAI-compatible API server backed by ChatGPT/Codex OAuth",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eunho-J/codex-as-api.git",
    "directory": "ts"
  },
  "keywords": [
    "codex",
    "chatgpt",
    "openai",
    "oauth",
    "api",
    "proxy",
    "openai-compatible"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "codex-as-api": "dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "npx tsx --test src/__tests__/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
